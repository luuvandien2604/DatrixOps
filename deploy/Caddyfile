{
	auto_https off
	admin off
}

:80 {
	header {
		X-DatrixOps-Gateway "caddy"
		-Server
	}

	# API and both reverse-terminal WebSocket channels go straight to Go.
	# Caddy preserves Upgrade/Connection and X-Forwarded-Host automatically.
	@api path /api/v1 /api/v1/*
	reverse_proxy @api backend:8080 {
		header_up X-DatrixOps-Gateway "caddy"
	}

	# Dashboard, documentation, installers, and signed Agent releases.
	reverse_proxy frontend:3000
}
