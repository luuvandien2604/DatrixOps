+//go:build !windows
+
+package terminal
+
+import (
+	"bytes"
+	"context"
+	"io"
+	"os/exec"
+	"testing"
+	"time"
+)
+
+func TestStartTerminalPTYProvidesControllingTTY(t *testing.T) {
+	t.Parallel()
+
+	command := exec.Command(
+		"/bin/sh",
+		"-c",
+		`if [ -t 0 ] && [ -t 1 ] && [ -t 2 ]; then printf 'headless-pty-ok\n'; else printf 'missing-controlling-tty\n'; exit 42; fi`,
+	)
+	command.Env = terminalEnvironment(100, 30)
+	command.Dir = terminalWorkingDirectory()
+
+	pseudoTerminal, err := startTerminalPTY(command, 100, 30)
+	if err != nil {
+		t.Fatalf("startTerminalPTY: %v", err)
+	}
+	defer pseudoTerminal.Close()
+
+	outputCh := make(chan []byte, 1)
+	go func() {
+		output, _ := io.ReadAll(pseudoTerminal)
+		outputCh <- output
+	}()
+
+	ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
+	defer cancel()
+	if err := waitTerminalProcess(ctx, command); err != nil {
+		t.Fatalf("waitTerminalProcess: %v", err)
+	}
+	_ = pseudoTerminal.Close()
+
+	select {
+	case output := <-outputCh:
+		if !bytes.Contains(output, []byte("headless-pty-ok")) {
+			t.Fatalf("shell did not receive a controlling TTY; output: %q", output)
+		}
+	case <-time.After(time.Second):
+		t.Fatal("timed out reading PTY output")
+	}
+}
