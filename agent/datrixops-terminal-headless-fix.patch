@@ -0,0 +1,10 @@
+package terminal
+
+import "io"
+
+// terminalPTY is the minimum PTY surface needed by the terminal session.
+// Platform-specific implementations live in pty_unix.go and pty_windows.go.
+type terminalPTY interface {
+	io.ReadWriteCloser
+	Resize(width, height int) error
+}
diff --git a/agent/internal/terminal/pty_unix.go b/agent/internal/terminal/pty_unix.go
new file mode 100644
index 0000000..d43f29d
--- /dev/null
+++ b/agent/internal/terminal/pty_unix.go
@@ -0,0 +1,81 @@
+//go:build !windows
+
+package terminal
+
+import (
+	"context"
+	"errors"
+	"io"
+	"os"
+	"os/exec"
+	"syscall"
+
+	"github.com/creack/pty"
+)
+
+type unixPTY struct {
+	master *os.File
+}
+
+func startTerminalPTY(command *exec.Cmd, cols, rows int) (terminalPTY, error) {
+	master, err := pty.StartWithSize(command, &pty.Winsize{
+		Cols: uint16(cols), // values are clamped before this call
+		Rows: uint16(rows),
+	})
+	if err != nil {
+		return nil, err
+	}
+	return &unixPTY{master: master}, nil
+}
+
+func (p *unixPTY) Read(data []byte) (int, error) {
+	return p.master.Read(data)
+}
+
+func (p *unixPTY) Write(data []byte) (int, error) {
+	return p.master.Write(data)
+}
+
+func (p *unixPTY) Close() error {
+	return p.master.Close()
+}
+
+func (p *unixPTY) Resize(width, height int) error {
+	return pty.Setsize(p.master, &pty.Winsize{
+		Cols: uint16(width), // values are clamped before this call
+		Rows: uint16(height),
+	})
+}
+
+func waitTerminalProcess(ctx context.Context, command *exec.Cmd) error {
+	done := make(chan error, 1)
+	go func() {
+		done <- command.Wait()
+	}()
+
+	select {
+	case err := <-done:
+		return err
+	case <-ctx.Done():
+		terminateTerminalProcess(command)
+		<-done
+		return ctx.Err()
+	}
+}
+
+func terminateTerminalProcess(command *exec.Cmd) {
+	if command == nil || command.Process == nil {
+		return
+	}
+
+	// creack/pty starts the command in a new session. Killing the negative PID
+	// terminates the complete shell process group, including child commands.
+	_ = syscall.Kill(-command.Process.Pid, syscall.SIGKILL)
+	_ = command.Process.Kill()
+}
+
+func terminalReadClosed(err error) bool {
+	return errors.Is(err, io.EOF) ||
+		errors.Is(err, os.ErrClosed) ||
+		errors.Is(err, syscall.EIO)
+}
