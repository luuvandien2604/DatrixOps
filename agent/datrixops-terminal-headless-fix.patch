--- /dev/null
+++ b/agent/internal/terminal/client_test.go
@@ -0,0 +1,60 @@
+package terminal
+
+import "testing"
+
+func TestTerminalURL(t *testing.T) {
+	t.Parallel()
+
+	tests := []struct {
+		name      string
+		serverURL string
+		want      string
+		wantError bool
+	}{
+		{
+			name:      "configured API base path",
+			serverURL: "https://datrixops.example/api/v1",
+			want:      "wss://datrixops.example/api/v1/agent/terminal",
+		},
+		{
+			name:      "default API base path",
+			serverURL: "http://127.0.0.1:8080",
+			want:      "ws://127.0.0.1:8080/api/v1/agent/terminal",
+		},
+		{
+			name:      "trailing slash",
+			serverURL: "https://datrixops.example/api/v1/",
+			want:      "wss://datrixops.example/api/v1/agent/terminal",
+		},
+		{
+			name:      "unsupported scheme",
+			serverURL: "ftp://datrixops.example/api/v1",
+			wantError: true,
+		},
+		{
+			name:      "missing host",
+			serverURL: "/api/v1",
+			wantError: true,
+		},
+	}
+
+	for _, test := range tests {
+		test := test
+		t.Run(test.name, func(t *testing.T) {
+			t.Parallel()
+			got, err := terminalURL(test.serverURL)
+			if test.wantError {
+				if err == nil {
+					t.Fatalf("terminalURL(%q) expected an error, got %q", test.serverURL, got)
+				}
+				return
+			}
+			if err != nil {
+				t.Fatalf("terminalURL(%q): %v", test.serverURL, err)
+			}
+			if got != test.want {
+				t.Fatalf("terminalURL(%q) = %q, want %q", test.serverURL, got, test.want)
+			}
+		})
+	}
+}
