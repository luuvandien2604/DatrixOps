+//go:build windows
+
+package terminal
+
+import (
+	"context"
+	"errors"
+	"io"
+	"os"
+	"os/exec"
+
+	"github.com/charmbracelet/x/xpty"
+)
+
+type windowsPTY struct {
+	xpty.Pty
+}
+
+func startTerminalPTY(command *exec.Cmd, cols, rows int) (terminalPTY, error) {
+	pseudoTerminal, err := xpty.NewPty(cols, rows)
+	if err != nil {
+		return nil, err
+	}
+	if err := pseudoTerminal.Start(command); err != nil {
+		_ = pseudoTerminal.Close()
+		return nil, err
+	}
+	return &windowsPTY{Pty: pseudoTerminal}, nil
+}
+
+func waitTerminalProcess(ctx context.Context, command *exec.Cmd) error {
+	return xpty.WaitProcess(ctx, command)
+}
+
+func terminateTerminalProcess(command *exec.Cmd) {
+	if command == nil || command.Process == nil {
+		return
+	}
+	_ = command.Process.Kill()
+}
+
+func terminalReadClosed(err error) bool {
+	return errors.Is(err, io.EOF) || errors.Is(err, os.ErrClosed)
+}
